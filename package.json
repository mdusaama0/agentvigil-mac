{
  "name": "agentvigil",
  "version": "1.0.1",
  "description": "Fleet watchdog for AI coding agent sessions — monitor Claude Code, Codex and Amp from your phone",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agentvigil": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://agentvigil.app",
