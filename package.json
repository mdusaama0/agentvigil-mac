    "url": "git+https://github.com/mdusaama0/agentvigil-mac.git"
  },
  "author": "Md Usama",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx src/index.ts setup",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
